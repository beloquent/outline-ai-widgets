# Outline + Widget Framework - Docker Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED SECRETS
# =============================================================================
# Generate with: openssl rand -hex 32
SECRET_KEY=
UTILS_SECRET=

# Your public URL (include https:// for production)
URL=https://your-domain.com

# =============================================================================
# DATABASE
# =============================================================================
# Custom database password (CHANGE IN PRODUCTION!)
POSTGRES_PASSWORD=outline_password

# Redis password (CHANGE IN PRODUCTION!)
REDIS_PASSWORD=redis_password

# =============================================================================
# AI FEATURES (Optional)
# =============================================================================
# OpenAI API key for AI Copilot, RAG, and document generation
OPENAI_API_KEY=

# Outline API key for AI service to access documents (for reindexing)
# Create via Outline Settings -> API -> Create new API key
# Can also be configured via AI Settings UI after deployment
OUTLINE_API_KEY=

# Admin secret for AI service configuration API
# Generate with: openssl rand -hex 32
AI_ADMIN_SECRET=

# CSRF secret for session-based requests (optional - for future use)
# When set, validates X-CSRF-Token headers if provided
# Generate with: openssl rand -hex 32
AI_CSRF_SECRET=

# =============================================================================
# LOGGING
# =============================================================================
# Log level for all services (debug, info, warn, error)
# Use 'debug' for troubleshooting startup issues or request tracing
# Default: info
LOG_LEVEL=info

# =============================================================================
# SECURITY
# =============================================================================
# Enforce HTTPS (set to false only for local development)
FORCE_HTTPS=true

# Enable Content Security Policy headers (recommended: true)
ENABLE_CSP=true

# CSP Report-Only mode (for testing CSP without blocking - set to false in production)
CSP_REPORT_ONLY=false

# Enable origin validation for session-authenticated requests (recommended: true)
ENFORCE_ORIGIN_CHECK=true

# Additional trusted origins (comma-separated, e.g., https://admin.example.com)
TRUSTED_ORIGINS=

# Name of your existing Outline Docker container (run: docker ps | grep outline)
# The Gateway proxies to this container on the outline_default network.
OUTLINE_CONTAINER_NAME=outline_outline_1

# Gateway bind IP (use 0.0.0.0 to expose directly, 127.0.0.1 for reverse proxy)
# IMPORTANT: Use 127.0.0.1 with a reverse proxy (nginx/traefik) for production
# IMPORTANT: Your reverse proxy MUST point to port 5000 (Gateway), NOT port 3000
# (Outline directly). The Gateway injects the widget into Outline's HTML responses.
GATEWAY_BIND_IP=127.0.0.1

# =============================================================================
# AUTHENTICATION (Configure at least one)
# =============================================================================
# Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Slack OAuth
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=

# Azure AD OAuth
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_RESOURCE_APP_ID=

# OIDC Provider
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_AUTH_URI=
# OIDC_TOKEN_URI=
# OIDC_USERINFO_URI=
# OIDC_DISPLAY_NAME=

# =============================================================================
# EMAIL (Optional)
# =============================================================================
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=hello@example.com
# SMTP_SECURE=false
