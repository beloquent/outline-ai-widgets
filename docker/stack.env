# Outline AI Widgets - Stack Environment Variables
# Override these in Portainer's environment variables section

# AI Postgres password (for the dedicated pgvector database)
AI_POSTGRES_PASSWORD=ai_service_password

# Name of your existing Outline container (check Portainer -> Containers)
OUTLINE_CONTAINER_NAME=outline_outline_1

# Gateway bind IP (use 0.0.0.0 to expose on all interfaces)
GATEWAY_BIND_IP=0.0.0.0

# AI Service secrets (generate with: openssl rand -hex 32)
AI_ADMIN_SECRET=
AI_CSRF_SECRET=

# OpenAI API key for AI features
OPENAI_API_KEY=

# Outline API key (create in Outline Settings -> API)
OUTLINE_API_KEY=

# Security settings
ENABLE_CSP=true
CSP_REPORT_ONLY=false
ENFORCE_ORIGIN_CHECK=true
TRUSTED_ORIGINS=

# Logging (debug, info, warn, error)
LOG_LEVEL=info
